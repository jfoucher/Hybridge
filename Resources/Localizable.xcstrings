    "That entity is not enabled for the watch" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Diese Entität ist für die Uhr nicht aktiviert"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esa entidad no está habilitada para el reloj"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cette entité n’est pas activée pour la montre"
          }
        }
      }
    },
    "The 16-byte key (32 hex characters) extracted from your watch — each watch has its own. Spaces and a 0x prefix are ignored. Stored in the iOS Keychain." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der aus Ihrer Uhr extrahierte 16-Byte-Schlüssel (32 Hexadezimalzeichen) – jede Uhr hat ihren eigenen. Leerzeichen und ein 0x-Präfix werden ignoriert. Im iOS Schlüsselbund gespeichert."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La clave de 16 bytes (32 caracteres hexadecimales) extraída de su reloj; cada reloj tiene la suya. Se ignoran los espacios y el prefijo 0x. Almacenado en el llavero iOS."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La clé de 16 octets (32 caractères hexadécimaux) extraite de votre montre — chaque montre a la sienne. Les espaces et le préfixe 0x sont ignorés. Stocké dans le trousseau iOS."
          }
        }
      }
    },
    "The app asks for it when you first connect a watch and stores it in the iOS Keychain — each watch keeps its own key." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die App fragt danach, wenn Sie eine Uhr zum ersten Mal verbinden, und speichert sie im iOS Schlüsselbund – jede Uhr behält ihren eigenen Schlüssel."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La aplicación la solicita cuando conecta un reloj por primera vez y la almacena en el llavero iOS: cada reloj guarda su propia clave."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'application le demande lorsque vous connectez une montre pour la première fois et la stocke dans le trousseau iOS — chaque montre conserve sa propre clé."
          }
        }
      }
    },
    "The calmest 5% of heart-rate readings while inactive, per day." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die ruhigsten 5 % der Herzfrequenzmessungen bei Inaktivität pro Tag."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El 5 % de las lecturas de frecuencia cardíaca más tranquilas mientras estás inactivo, por día."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les 5 % de lectures de fréquence cardiaque les plus calmes pendant l'inactivité, par jour."
          }
        }
      }
    },
    "The key could not be saved to the iOS Keychain. Unlock the device and try again." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Schlüssel konnte nicht im iOS Schlüsselbund gespeichert werden. Entsperren Sie das Gerät und versuchen Sie es erneut."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La clave no se pudo guardar en el llavero iOS. Desbloquea el dispositivo y vuelve a intentarlo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La clé n'a pas pu être enregistrée dans le trousseau iOS. Déverrouillez l'appareil et réessayez."
          }
        }
      }
    },
    "The key must be exactly 32 hex characters (16 bytes)." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Schlüssel muss genau 32 Hexadezimalzeichen (16 Byte) lang sein."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La clave debe tener exactamente 32 caracteres hexadecimales (16 bytes)."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La clé doit contenir exactement 32 caractères hexadécimaux (16 octets)."
          }
        }
      }
    },
    "The offset is baked in at install time — reinstall the face after DST changes." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Versatz wird bei der Installation festgelegt – installiere das Zifferblatt nach der Zeitumstellung erneut."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El desfase se fija al instalar; vuelve a instalar la esfera después de un cambio de horario de verano."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le décalage est intégré lors de l’installation — réinstallez le cadran après un changement d’heure d’été ou d’hiver."
          }
        }
      }
    },
    "The test notification goes through the watch protocol directly, so it works even before Bluetooth pairing." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Testbenachrichtigung läuft direkt über das Uhrenprotokoll, sodass sie bereits vor dem Bluetooth Pairing funktioniert."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La notificación de prueba pasa directamente por el protocolo del reloj, por lo que funciona incluso antes del emparejamiento Bluetooth."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La notification de test passe directement par le protocole de la montre, elle fonctionne donc même avant l'appairage Bluetooth."
          }
        }
      }
    },
    "The watch detects the activity after the configured number of minutes; \"ask first\" shows a confirmation on the watch instead of starting silently." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Uhr erkennt die Aktivität nach der konfigurierten Anzahl von Minuten; „Zuerst fragen“ zeigt eine Bestätigung auf der Uhr an, anstatt lautlos zu starten."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El reloj detecta la actividad después del número de minutos configurado; \"Preguntar primero\" muestra una confirmación en el reloj en lugar de comenzar en silencio."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La montre détecte l'activité après le nombre de minutes configuré ; \"demander d'abord\" affiche une confirmation sur la montre au lieu de démarrer silencieusement."
          }
        }
      }
    },
    "The watch display is monochrome, so icons are SF Symbol glyphs rather than the app's real artwork. Any SF Symbol name works." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Das Display der Uhr ist monochrom, daher handelt es sich bei den Symbolen um SF Symbol Glyphen und nicht um die eigentliche Grafik der App. Jeder SF Symbol-Name funktioniert."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La pantalla del reloj es monocromática, por lo que los íconos son SF Symbol glifos en lugar del arte real de la aplicación. Cualquier nombre SF Symbol funciona."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'affichage de la montre est monochrome, les icônes sont donc des glyphes SF Symbol plutôt que les véritables illustrations de l'application. N'importe quel nom SF Symbol fonctionne."
          }
        }
      }
    },
    "The watch moved all hands to what it thinks is their zero position. Nudge the selected hand by degrees until it matches, then save." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Uhr hat alle Zeiger auf ihre vermeintliche Nullposition gestellt. Bewege den ausgewählten Zeiger gradweise bis zur richtigen Position und speichere dann."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El reloj ha movido todas las manecillas a la que considera su posición cero. Ajusta la manecilla seleccionada grado a grado hasta que coincida y guarda."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La montre a placé toutes les aiguilles à leur position zéro supposée. Ajustez l’aiguille sélectionnée degré par degré jusqu’à ce qu’elle corresponde, puis enregistrez."
          }
        }
      }
    },
    "The watch moved both hands to what it thinks is 12 o'clock. Nudge the selected hand by degrees until it matches the target above, then save." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Uhr hat beide Zeiger auf ihre vermeintliche 12-Uhr-Position gestellt. Bewege den ausgewählten Zeiger gradweise bis zum Ziel oben und speichere dann."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El reloj ha movido ambas manecillas a la que considera la posición de las 12. Ajusta la manecilla seleccionada grado a grado hasta que coincida con el objetivo de arriba y guarda."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La montre a placé les deux aiguilles à la position qu’elle considère comme 12 heures. Ajustez l’aiguille sélectionnée degré par degré jusqu’à ce qu’elle corresponde à la cible ci-dessus, puis enregistrez."
          }
        }
      }
    },
    "These preferences apply to every compatible watch when it connects. Body metrics let supported watches estimate calories." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Diese Einstellungen gelten für jede kompatible Uhr, wenn eine Verbindung hergestellt wird. Mit Körpermesswerten können unterstützte Uhren Kalorien schätzen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Estas preferencias se aplican a todos los relojes compatibles cuando se conectan. Las métricas corporales permiten a los relojes compatibles estimar las calorías."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ces préférences s'appliquent à chaque montre compatible lorsqu'elle se connecte. Les mesures corporelles permettent aux montres prises en charge d'estimer les calories."
          }
        }
      }
    },
    "These preferences are shared by all compatible watches and applied when they connect." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Diese Einstellungen werden von allen kompatiblen Uhren geteilt und beim Herstellen einer Verbindung angewendet."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Estas preferencias son compartidas por todos los relojes compatibles y se aplican cuando se conectan."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ces préférences sont partagées par toutes les montres compatibles et appliquées lors de leur connexion."
          }
        }
      }
    },
    "Thin circle" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dünner Kreis"
          }
        },
