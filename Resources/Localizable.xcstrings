        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Entfernt die Uhr, ihren Authentifizierungsschlüssel und ihre Einstellungen von diesem iPhone. Synchronisierte Fitnessdaten bleiben erhalten. Die Uhr selbst wird nicht zurückgesetzt."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elimina el reloj, su clave de autenticación y su configuración de este iPhone. Se mantienen los datos de fitness sincronizados. El reloj en sí no se reinicia."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
