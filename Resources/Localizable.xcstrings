    "Anyone able to observe your local network may capture this long-lived token. Never enable this for a public or remote host." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jeder, der Ihren lokalen Netzwerkverkehr beobachten kann, könnte dieses langlebige Token abfangen. Aktivieren Sie diese Option niemals für einen öffentlichen oder entfernten Host."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cualquiera que pueda observar tu red local podría capturar este token de larga duración. No actives nunca esta opción para un host público o remoto."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toute personne pouvant surveiller votre réseau local pourrait intercepter ce jeton d’accès longue durée. N’activez jamais cette option pour un hôte public ou distant."
          }
        }
      }
    },
