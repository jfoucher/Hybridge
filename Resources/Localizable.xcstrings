    "Bluetooth is off" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bluetooth ist ausgeschaltet"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bluetooth está apagado"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bluetooth est éteint"
          }
        }
      }
    },
    "Bluetooth is required up front. Everything else is asked only when you enable it: location for weather and workout GPS, calendar for event sync, Apple Health for fitness export, notifications for the low-battery alert." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bluetooth ist im Voraus erforderlich. Alles andere wird nur abgefragt, wenn Sie es aktivieren: Standort für Wetter- und Trainings-GPS, Kalender für die Ereignissynchronisierung, Apple Health für den Fitnessexport, Benachrichtigungen für die Warnung bei niedrigem Batteriestand."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bluetooth se requiere por adelantado. Todo lo demás se pregunta solo cuando lo habilitas: ubicación para el clima y GPS de entrenamiento, calendario para sincronización de eventos, Apple Health para exportación de actividad física, notificaciones para alerta de batería baja."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bluetooth est requis à l'avance. Tout le reste n'est demandé que lorsque vous l'activez : localisation pour la météo et le GPS d'entraînement, calendrier pour la synchronisation des événements, Apple Health pour l'exportation de la condition physique, notifications pour l'alerte de batterie faible."
          }
        }
      }
    },
