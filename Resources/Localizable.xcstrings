    "Sun clock: the orb rides a 24h ring, sunrise/sunset times and how much daylight is left." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sonnenuhr: Die Kugel dreht sich um einen 24-Stunden-Ring, zeigt die Zeiten des Sonnenaufgangs und -untergangs an und zeigt an, wie viel Tageslicht noch übrig ist."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reloj solar: el orbe gira en un anillo de 24 horas, las horas de salida y puesta del sol y cuánta luz del día queda."
          }
        },
        "fr" : {
