    "Sleep & wellness" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Schlaf & Wellness"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sueño y bienestar"
          }
