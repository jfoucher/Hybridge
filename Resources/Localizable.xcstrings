    "Home occupies the 3 o’clock slot. This order fills the remaining slots clockwise. Swipe to remove or drag to reorder." : {
      "comment" : "A description of how to reorder entities.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Home belegt die 3-Uhr-Position. Diese Reihenfolge füllt die übrigen Positionen im Uhrzeigersinn. Zum Entfernen wischen oder zum Neuordnen ziehen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inicio ocupa la posición de las 3 en punto. Este orden rellena las posiciones restantes en el sentido de las agujas del reloj. Desliza para eliminar o arrastra para reordenar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Accueil occupe l'emplacement de 3 heures. Cet ordre remplit les emplacements restants dans le sens des aiguilles d'une montre. Balayez pour supprimer ou faites glisser pour réorganiser."
          }
        }
      }
    },
