    "Designs stay on your phone. Install pushes the 2-bit e-ink render over Bluetooth — larger photos take a few seconds." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Entwürfe bleiben auf deinem Telefon. Beim Installieren wird die 2-Bit-E-Ink-Darstellung über Bluetooth übertragen – größere Fotos benötigen einige Sekunden."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los diseños permanecen en tu teléfono. Al instalar, la imagen de tinta electrónica de 2 bits se envía por Bluetooth; las fotos grandes tardan unos segundos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les créations restent sur votre téléphone. L’installation envoie le rendu e‑ink 2 bits par Bluetooth — les grandes photos prennent quelques secondes."
          }
        }
      }
    },
