    },
    "This wipes all data, apps and pairing from the watch and reboots it. You will need to set it up again from scratch." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dadurch werden alle Daten, Apps und Kopplungen von der Uhr gelöscht und die Uhr neu gestartet. Sie müssen es von Grund auf neu einrichten."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esto borra todos los datos, aplicaciones y emparejamientos del reloj y lo reinicia. Deberá configurarlo nuevamente desde cero."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cela efface toutes les données, applications et couplages de la montre et la redémarre. Vous devrez le reconfigurer à partir de zéro."
