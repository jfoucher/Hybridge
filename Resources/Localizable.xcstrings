    "When saving, both hands must physically point straight up at 12 o'clock, like shown above." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beim Speichern müssen beide Zeiger physisch gerade nach oben auf die 12-Uhr-Position zeigen, wie oben gezeigt."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Al guardar, ambas manecillas deben apuntar físicamente hacia arriba a las 12 en punto, como se muestra arriba."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lors de la sauvegarde, les deux aiguilles doivent physiquement pointer vers le haut à 12 heures, comme indiqué ci-dessus."
          }
        }
      }
    },
    "When saving, both main hands must physically point straight up at 12 o'clock, and the small hand at its dial's top marker." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beim Speichern müssen beide Hauptzeiger physisch gerade nach oben auf 12 Uhr zeigen und der kleine Zeiger muss sich auf der oberen Markierung des Zifferblatts befinden."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Al guardar, ambas manecillas principales deben apuntar físicamente hacia arriba a las 12 en punto y la manecilla pequeña al marcador superior de la esfera."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lors de la sauvegarde, les deux aiguilles principales doivent pointer physiquement vers le haut à 12 heures, et la petite aiguille vers le marqueur supérieur de son cadran."
          }
        }
      }
    },
