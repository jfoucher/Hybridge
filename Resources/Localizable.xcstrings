        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Editar alarma"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Modifier l'alarme"
          }
        }
      }
    },
    "Enable quiet hours" : {
