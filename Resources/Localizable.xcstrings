    "Use your Home Assistant base URL and a Long-Lived Access Token from the bottom of your Home Assistant profile. HTTPS protects the token and is required by default." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verwenden Sie Ihre Home-Assistant-Basis-URL und ein langlebiges Zugriffstoken vom unteren Ende Ihres Home-Assistant-Profils. HTTPS schützt das Token und ist standardmäßig erforderlich."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utiliza la URL base de Home Assistant y un token de acceso de larga duración disponible al final de tu perfil de Home Assistant. HTTPS protege el token y es obligatorio de forma predeterminada."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utilisez l’URL de base de Home Assistant et un jeton d’accès longue durée disponible au bas de votre profil Home Assistant. HTTPS protège le jeton et est requis par défaut."
          }
        }
