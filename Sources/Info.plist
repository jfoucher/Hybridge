<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>eu.sixpixels.hybridge.refresh</string>
	</array>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Hybridge</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
	<key>NSAppleMusicUsageDescription</key>
	<string>Lets configured Q watch buttons control Apple Music playback while Hybridge is running.
</string>
	<key>NSBluetoothAlwaysUsageDescription</key>
	<string>Hybridge connects to your supported Fossil hybrid watch over Bluetooth to set the time, alarms and compatible settings.
</string>
	<key>NSCalendarsFullAccessUsageDescription</key>
	<string>Sends your upcoming events to your watch, and can check whether you're in a meeting to enable quiet hours automatically. Calendar data for the meeting check never leaves your phone.
</string>
	<key>NSHealthShareUsageDescription</key>
	<string>Hybridge does not read any Health data.
</string>
	<key>NSHealthUpdateUsageDescription</key>
	<string>Hybridge writes watch-recorded steps, heart rate, calories, SpO2, sleep and workouts into Apple Health.
</string>
	<key>NSHumanReadableCopyright</key>
	<string>© 2026 Jonathan Foucher</string>
	<key>NSLocalNetworkUsageDescription</key>
	<string>Connects to your Home Assistant server on your local network when the Home Assistant watch app requests entities or sends a control.
</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Records GPS distance for workouts started while Hybridge is open (or from its Workout GPS screen). An active session can continue in the background with the blue status indicator and stops with the workout. Also fetches local weather to show on your watch.
</string>
	<key>UIAppFonts</key>
	<array>
		<string>InstrumentSerif-Regular.ttf</string>
		<string>IBMPlexMono-Regular.ttf</string>
		<string>IBMPlexMono-Medium.ttf</string>
		<string>IBMPlexMono-SemiBold.ttf</string>
	</array>
	<key>UIBackgroundModes</key>
	<array>
		<string>bluetooth-central</string>
		<string>location</string>
		<string>fetch</string>
	</array>
	<key>UILaunchScreen</key>
	<dict/>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
</dict>
</plist>
